# TAAFI AI Dashboard Environment Variables

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgres://taafi:taafi@localhost:5432/taafi
DASHBOARD_DB_URL=sqlite+aiosqlite:///./taafi_dashboard.db
POSTGRES_PASSWORD=change-me-in-production

# ─── Authentication ────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Qwen Cloud API ───────────────────────────────────────────
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen-plus

# ─── LLM Budget ───────────────────────────────────────────────
DAILY_BUDGET=5.0

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Ollama (Local Fallback) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ─── Logging ──────────────────────────────────────────────────
RUST_LOG=info
TAAFI_LOG_FORMAT=json
